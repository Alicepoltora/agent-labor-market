# Server
PORT=3000
NODE_ENV=development

# Circle API
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here
CIRCLE_WALLET_SET_ID=your_wallet_set_id_here

# Blockchain (Sepolia testnet)
RPC_URL=https://sepolia.infura.io/v3/your_infura_key
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Groq (LLM Judge) — get free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Platform config
PLATFORM_FEE_PERCENT=2
ESCROW_TIMEOUT_HOURS=24
JUDGE_AUTO_THRESHOLD=0.8
